@typeparam TItem
@foreach (var item in In ?? Array.Empty<TItem>())
{
	@if (ShowItemsWhen)
	{
		@ChildContent(item)
	}
}
@code
{
	[Parameter] public RenderFragment<TItem> ChildContent { get; set; }
	[Parameter] public IEnumerable<TItem> In { get; set; }
	[Parameter] public bool ShowItemsWhen { get; set; } = true;
}