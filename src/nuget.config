<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <clear /> 
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
        <add key="github-saascade" value="https://nuget.pkg.github.com/saascade/index.json" />
    </packageSources>
   
    <packageSourceMapping> 
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>
        <packageSource key="github-saascade">
            <package pattern="Saascade.Blazor.Components.*" /> 
        </packageSource>
    </packageSourceMapping>
</configuration>