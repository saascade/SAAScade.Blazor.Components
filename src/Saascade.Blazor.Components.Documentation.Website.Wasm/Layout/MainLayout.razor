@using Saascade.Blazor.Components.Documentation.Website.Wasm.Components
@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject TechFilterService FilterService

@inject TechFilterService FilterService


@{
    var path = Navigation.ToBaseRelativePath(Navigation.Uri);
    var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
    var breadcrumb = "Documentation";

    foreach (var segment in segments)
    {
        var formatted = char.ToUpper(segment[0]) + segment.Substring(1);
        breadcrumb += " / " + formatted;
    }
}

<div class="app-shell @(darkMode ? "dark-theme" : "light-theme")">
    <header class="topbar">
        <div class="topbar-left @(menuOpen ? "" : "closed")">
            <div class="brand">Saascade Docs</div>
        </div>
        <div class="topbar-center">
            <nav class="topnav">
                <button class="menu-toggle" aria-label="Toggle menu" @onclick="ToggleMenu">☰</button>
                <a class="top-action" href="/">Home</a>
                <a class="top-action" href="docs">Docs</a>
            </nav>
        </div>
        <div class="topbar-right">
            <a class="top-action" href="pricing">Pricing</a>
            <a class="top-action" href="account">Account</a>
            <button class="theme-toggle" @onclick="ToggleTheme">
                🌙
            </button>
            <div class="topbar-search">
                <input placeholder="Search..." />
            </div>
        </div>
    </header>

    <TechFilterBar />

    <div class="layout-body">
        <aside class="sidebar @(menuOpen ? "open" : "")" aria-label="Primary navigation">
            <nav class="sidebar-nav">
                <ul>
                    <li class="sidebar-section-label">Getting Started</li>
                    <li><NavLink class="sidebar-link" href="overview">Overview</NavLink></li>
                    <li><NavLink class="sidebar-link" href="installation">Installation</NavLink></li>
                    <li><NavLink class="sidebar-link" href="quick-start">Quick Start</NavLink></li>

                    <li><hr /></li>

                    <li class="sidebar-section-label">Design Systems</li>
                    <li><NavLink class="sidebar-link" href="design-systems">How It Works</NavLink></li>
                    @if (FilterService.IsVisible("bootstrap"))
                    {
                        <li><NavLink class="sidebar-link" href="bootstrap5">Bootstrap 5</NavLink></li>
                    }
                    @if (FilterService.IsVisible("daisyui"))
                    {
                        <li><NavLink class="sidebar-link" href="daisyui">DaisyUI</NavLink></li>
                    }
                    @if (FilterService.IsVisible("basecoat"))
                    {
                        <li><NavLink class="sidebar-link" href="basecoat">Basecoat</NavLink></li>
                    }
                    <li><NavLink class="sidebar-link" href="custom-themes">Custom Themes</NavLink></li>

                    <li><hr /></li>

                    <li class="sidebar-section-label">Layout</li>
                    <li><NavLink class="sidebar-link" href="column">Column</NavLink></li>
                    <li><NavLink class="sidebar-link" href="div-section-main">Div</NavLink></li>
                    <li><NavLink class="sidebar-link" href="header-footer">Header &amp; Footer</NavLink></li>
                    <li><NavLink class="sidebar-link" href="hero">Hero</NavLink></li>
                    <li><NavLink class="sidebar-link" href="drawer">Drawer</NavLink></li>

                    <li><hr /></li>

                    <li class="sidebar-section-label">Typography</li>
                    <li><NavLink class="sidebar-link" href="headings">Headings (H1–H6)</NavLink></li>
                    <li><NavLink class="sidebar-link" href="paragraph">Paragraph</NavLink></li>

                    <li><hr /></li>

                    <li class="sidebar-section-label">Data Display</li>
                    <li><NavLink class="sidebar-link" href="cards">Card</NavLink></li>
                    <li><NavLink class="sidebar-link" href="cards-grid">Cards Grid</NavLink></li>
                    <li><NavLink class="sidebar-link" href="carousel">Carousel</NavLink></li>
                    <li><NavLink class="sidebar-link" href="figure-image">Figure &amp; Image</NavLink></li>
                    <li><NavLink class="sidebar-link" href="list">List</NavLink></li>

                    <li class="sidebar-section-label">Navigation</li>
                    <li><NavLink class="sidebar-link" href="anchor">Anchor / Hyperlink</NavLink></li>
                    <li><NavLink class="sidebar-link" href="navbar">Navbar</NavLink></li>

                    <li class="sidebar-section-label">Actions</li>
                    <li><NavLink class="sidebar-link" href="button">Button</NavLink></li>
                    <li><NavLink class="sidebar-link" href="semantic-buttons">Semantic Buttons</NavLink></li>

                    <li><hr /></li>

                    <li class="sidebar-section-label">Advanced</li>
                    <li><NavLink class="sidebar-link" href="base-components">Base Components</NavLink></li>
                    <li><NavLink class="sidebar-link" href="render-foreach">Render &amp; Foreach</NavLink></li>
                    <li><NavLink class="sidebar-link" href="name-attribute-selection">Name Attribute</NavLink></li>
                    <li><NavLink class="sidebar-link" href="create-design-system">Creating a Design System</NavLink></li>

                    <li><hr /></li>

                    <li><NavLink class="sidebar-link" href="api-reference">API Reference</NavLink></li>
                    <li><NavLink class="sidebar-link" href="integrations">Integrations</NavLink></li>
                    <li><NavLink class="sidebar-link" href="changelog">Changelog</NavLink></li>
                </ul>
            </nav>
        </aside>

        <main class="main-content @(menuOpen ? "menu-open" : "menu-closed")">
            <div class="page-header">
                <div class="breadcrumb">@breadcrumb</div>
            </div>
            <section class="doc-body">
                @Body
            </section>
        </main>
    </div>

    <footer class="site-footer">
        <div class="footer-columns">
            <div class="footer-col">
                <h4>Links</h4>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="overview">Overview</a></li>
                    <li><a href="https://github.com/saascade/SAAScade.Blazor.Components" target="_blank" rel="noopener noreferrer">GitHub ↗</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Guides</h4>
                <ul>
                    <li><a href="quick-start">Quick Start</a></li>
                    <li><a href="installation">Installation</a></li>
                    <li><a href="design-systems">Design Systems</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Community</h4>
                <ul>
                    <li><a href="https://github.com/saascade/SAAScade.Blazor.Components/issues" target="_blank" rel="noopener noreferrer">Issues ↗</a></li>
                    <li><a href="https://github.com/saascade/SAAScade.Blazor.Components/discussions" target="_blank" rel="noopener noreferrer">Discussions ↗</a></li>
                    <li><a href="https://www.nuget.org/packages?q=saascade" target="_blank" rel="noopener noreferrer">NuGet ↗</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            Copyright &copy; @DateTime.Now.Year Saascade.
        </div>
    </footer>
</div>

@code {
    bool menuOpen = true;

    void ToggleMenu()
    {
        menuOpen = !menuOpen;
    }

    bool darkMode = true;

    void ToggleTheme()
    {
        darkMode = !darkMode;
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        FilterService.OnChange += StateHasChanged;
    }

    async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var uri = new Uri(e.Location);
        if (string.IsNullOrEmpty(uri.Fragment))
        {
            await JS.InvokeVoidAsync("scrollToTop");
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        FilterService.OnChange -= StateHasChanged;
    }
}
