@using Saascade.Blazor.Components.Experimental 
<DynamicGrid TItem="DynamicRow"
             Items="@rows"
             RowIdSelector="@(r => r.Id)"
             LabelSelector="@(r => r.Label)"
             LabelColumnHeader="Component"
             DynamicAccessor="@(r => r.Values)">

    <CellTemplate Context="cell"> 
        @if (cell.Column == "__label")
        { 
            //The label
            <strong>@cell.Value</strong>
        }
        else
        { 
            //Column Value
            if (cell.Value is LevelOfSupport levelOfSupport)
            {
                <LevelOfSupportDisplayValue LevelOfSupport="levelOfSupport"/>
            }
        } 
    </CellTemplate>
</DynamicGrid>
@inject CssFrameworkService CssFrameworkService
@inject DesignSystemsService DesignSystemsService
@inject SaascadeComponentsService ComponentsService
@code 
{  
    protected override void OnInitialized()
    {
        try
        {
            var cssFrameworks = CssFrameworkService.GetCssFrameworksToShow();//.OrderBy(f => f.Humanize()).ToList();
            var components = ComponentsService.GetAllComponents();
            rows = BuildRows(cssFrameworks, components).OrderBy(r => r.Label).ToList();
        }
        catch (Exception e)
        {
            Console.WriteLine(e);
            throw;
        } 
        base.OnInitialized();
    }

    private IEnumerable<DynamicRow> BuildRows(IReadOnlyCollection<CssFramework> cssFrameworks, IReadOnlyCollection<BaseComponent> components) 
        => components.Select(component => new DynamicRow( Guid.CreateVersion7(), component.GetType().Name, CalculateLevelOfSupport(component, cssFrameworks)));

    private Dictionary<string, object?> CalculateLevelOfSupport(BaseComponent component, IReadOnlyCollection<CssFramework> cssFrameworks)
    {
        var support = new Dictionary<string, object?>();
        foreach (var framework in cssFrameworks)
        { 
            var designSystems = DesignSystemsService.GetAllDesignSystems(framework, verify: true);
            if (designSystems.Count > 0)
            {
                var allMatch = designSystems.All(ds => ds.SupportsComponent(component));
                if (allMatch)
                {
                    support.Add(framework.Humanize(), LevelOfSupport.Full);
                    continue;
                }

                var someMatch = designSystems.Any(ds => ds.SupportsComponent(component));
                if (someMatch)
                {
                    support.Add(framework.Humanize(), LevelOfSupport.Partial);
                    continue;
                }
            }  

            //None match
            support.Add(framework.Humanize(), LevelOfSupport.None);
        }
         
        return support;
    }


    private List<DynamicRow> rows = [];
} 