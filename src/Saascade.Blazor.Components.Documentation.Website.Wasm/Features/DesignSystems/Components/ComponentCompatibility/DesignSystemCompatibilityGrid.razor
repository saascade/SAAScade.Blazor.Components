@using Saascade.Blazor.Components.Experimental 
<DynamicGrid TItem="DynamicRow"
             Items="@rows"
             RowIdSelector="@(r => r.Id)"
             LabelSelector="@(r => r.Label)"
             LabelColumnHeader="Component"
             DynamicAccessor="@(r => r.Values)">

    <CellTemplate Context="cell"> 
        @if (cell.Column == "__label")
        { 
            //The label
            <LinkToComponentPage ComponentName="@cell.Value?.ToString()"/>
        }
        else
        { 
            //Column Value
            if (cell.Value is LevelOfSupport levelOfSupport)
            {
                <LevelOfSupportDisplayValue LevelOfSupport="levelOfSupport"/>
            }
        } 
    </CellTemplate>
</DynamicGrid>
@inject CssFrameworkService CssFrameworkService
@inject DesignSystemsService DesignSystemsService
@inject SaascadeComponentsService ComponentsService
@code 
{  
    [Parameter, EditorRequired] public CssFramework Framework { get; set; }
    
    protected override void OnInitialized()
    {
        try
        { 
            var components = ComponentsService.GetAllComponents();
            rows = BuildRows(components).OrderBy(r => r.Label).ToList();
        }
        catch (Exception e)
        {
            Console.WriteLine(e);
            throw;
        } 
        base.OnInitialized();
    }

    private IEnumerable<DynamicRow> BuildRows(IReadOnlyCollection<BaseComponent> components) 
        => components.Select(component => new DynamicRow( Guid.CreateVersion7(), component.GetType().Name, CalculateLevelOfSupport(component)));

    private Dictionary<string, object?> CalculateLevelOfSupport(BaseComponent component)
    {
        var support = new Dictionary<string, object?>();
    
        var designSystems = DesignSystemsService.GetAllDesignSystems(Framework, verify: true);
        foreach (var designSystem in designSystems.OrderBy(ds => ds.DisplayName))
        {
            var supportsComponent = designSystem.SupportsComponent(component);
            var levelOfSupport = supportsComponent ? LevelOfSupport.Full : LevelOfSupport.None; 
            support.Add(designSystem.DisplayName,levelOfSupport);
        } 
    
        return support;
    }


    private List<DynamicRow> rows = [];
} 