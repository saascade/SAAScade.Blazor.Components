@page "/api-reference"
<PageTitle>API Reference - Saascade Docs</PageTitle>

<h1 id="api-reference">API Reference</h1>

<div class="doc-layout">

<main class="documentation">

    <TechCard>
        <section class="card">

            <h2 id="components">Components</h2>

            <p class="subtitle">
                Complete list of all Saascade Blazor components and their parameters.
            </p>

            <hr />

            <h3>Layout</h3>
            <ul>
                <li><a href="column">Column</a></li>
                <li><a href="div-section-main">Div / Section / Main</a></li>
                <li><a href="header-footer">Header / Footer</a></li>
                <li><a href="hero">Hero</a></li>
                <li><a href="drawer">Drawer / DrawerSide / DrawerContent</a></li>
            </ul>

            <h3>Typography</h3>
            <ul>
                <li><a href="headings">H1 – H6</a></li>
                <li><a href="paragraph">P (Paragraph)</a></li>
            </ul>

            <h3>Data Display</h3>
            <ul>
                <li><a href="cards">Card / CardBody / CardTitle</a></li>
                <li><a href="cards-grid">CardsGrid</a></li>
                <li><a href="carousel">Carousel</a></li>
                <li><a href="figure-image">Figure / Img</a></li>
                <li><a href="list">Ul / Li</a></li>
            </ul>

            <h3>Navigation</h3>
            <ul>
                <li><a href="anchor">A (Anchor) / Hyperlink</a></li>
                <li><a href="navbar">Navbar</a></li>
            </ul>

            <h3>Actions</h3>
            <ul>
                <li><a href="button">Button</a></li>
                <li><a href="semantic-buttons">AcceptButton / CancelButton / CloseButton / DeleteButton / DestructiveButton</a></li>
            </ul>

        </section>
    </TechCard>

    <TechCard>
        <section class="card">

            <h2 id="base-classes">Base Classes</h2>

            <ul>
                <li><a href="base-components">BaseComponent</a></li>
                <li><a href="base-components">BaseComponentWithOptionalChildContent</a></li>
                <li><a href="base-components">BaseComponentWithRequiredChildContent</a></li>
            </ul>

        </section>
    </TechCard>

    <TechCard>
        <section class="card">

            <h2 id="design-system-interfaces">Design System Interfaces</h2>

            <ul>
                <li><a href="design-systems">IDesignSystem</a></li>
                <li><a href="design-systems">CssFramework (enum)</a></li>
            </ul>

        </section>
    </TechCard>

    <TechCard Tech="bootstrap">
        <section class="card">

            <h2 id="api-reference-bootstrap">Bootstrap 5 API Reference</h2>

            <p class="subtitle">Bootstrap 5 API Reference</p>

            <hr />

            <p>
                When Bootstrap 5 is the active design system, each component in the API reference
                maps to the corresponding Bootstrap CSS class. Card maps to the Bootstrap card
                component, Button maps to btn, Navbar maps to navbar, and so on. The Specialization
                parameter accepts any Bootstrap modifier token documented in the Bootstrap 5
                official documentation for the corresponding component.
            </p>

        </section>
    </TechCard>

    <TechCard Tech="daisyui">
        <section class="card">

            <h2 id="api-reference-daisyui">DaisyUI API Reference</h2>

            <p class="subtitle">DaisyUI API Reference</p>

            <hr />

            <p>
                When DaisyUI is the active design system, each component maps to the corresponding
                DaisyUI semantic class. Card maps to the DaisyUI card component with bg-base-100
                and shadow specializations, Button maps to btn, and Navbar maps to navbar. The
                Specialization parameter accepts any DaisyUI modifier token documented in the
                DaisyUI official component reference.
            </p>

        </section>
    </TechCard>

    <TechCard Tech="basecoat">
        <section class="card">

            <h2 id="api-reference-basecoat">Basecoat API Reference</h2>

            <p class="subtitle">Basecoat API Reference</p>

            <hr />

            <p>
                When Basecoat is the active design system, each component in the API reference
                is composed from Tailwind utility classes defined in the Basecoat library.
                The Specialization parameter accepts any additional Tailwind utility class that
                you want to apply on top of the Basecoat defaults. Refer to the Basecoat
                documentation for the specific utility class sets used for each component.
            </p>

        </section>
    </TechCard>

</main>

<TableOfContents Items="@([
    new TocItem("api-reference", "API Reference"),
    new TocItem("components", "Components", 2),
    new TocItem("base-classes", "Base Classes", 2),
    new TocItem("design-system-interfaces", "Design System Interfaces", 2),
    new TocItem("api-reference-bootstrap", "Bootstrap 5", 2),
    new TocItem("api-reference-daisyui", "DaisyUI", 2),
    new TocItem("api-reference-basecoat", "Basecoat", 2)
])" />

</div>
