@page "/list"
<PageTitle>List - Saascade Docs</PageTitle>

<h1 id="list">List (Ul / Li)</h1>

<div class="doc-layout">

<main class="documentation">

    <section class="card">

        <h2 id="overview">Overview</h2>

        <p class="subtitle">
            The <code>&lt;Ul&gt;</code> and <code>&lt;Li&gt;</code> components render
            semantic unordered list elements with design-system styling.
        </p>

        <hr />

        <h3>Basic Usage</h3>

        <pre><code>&lt;Ul&gt;
    &lt;Li&gt;First item&lt;/Li&gt;
    &lt;Li&gt;Second item&lt;/Li&gt;
    &lt;Li&gt;Third item&lt;/Li&gt;
&lt;/Ul&gt;</code></pre>

    </section>

    <section class="card">

        <h2 id="programmatic-lists">Programmatic Lists</h2>

        <p>
            Use the <code>&lt;Foreach&gt;</code> or <code>&lt;ListOf&gt;</code> base
            components to render lists from data collections. See the
            <a href="render-foreach">Render &amp; Foreach</a> page.
        </p>

    </section>

</main>

<TableOfContents Items="@([
    new TocItem("list", "List (Ul / Li)"),
