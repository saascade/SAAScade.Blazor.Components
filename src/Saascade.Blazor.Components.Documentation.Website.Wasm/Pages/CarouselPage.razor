@page "/carousel"
<PageTitle>Carousel - Saascade Docs</PageTitle>

<h1>Carousel</h1>

<main class="documentation">

    <section class="card">

        <h2>Overview</h2>

        <p class="subtitle">
            The <code>&lt;Carousel&gt;</code> component creates a slideshow
            for cycling through content — images, cards, or any child elements.
        </p>

        <hr />

        <h3>Basic Usage</h3>

        <pre><code>&lt;Carousel&gt;
    &lt;Img Src="slide1.jpg" /&gt;
    &lt;Img Src="slide2.jpg" /&gt;
    &lt;Img Src="slide3.jpg" /&gt;
&lt;/Carousel&gt;</code></pre>

    </section>

    <section class="card">

        <h2>Parameters</h2>

        <table>
            <thead>
                <tr><th>Parameter</th><th>Type</th><th>Description</th></tr>
            </thead>
            <tbody>
                <tr><td>Class</td><td>string?</td><td>Additional CSS classes.</td></tr>
                <tr><td>Style</td><td>string?</td><td>Inline styles.</td></tr>
                <tr><td>ChildContent</td><td>RenderFragment</td><td>Slide elements.</td></tr>
            </tbody>
        </table>

    </section>

</main>
