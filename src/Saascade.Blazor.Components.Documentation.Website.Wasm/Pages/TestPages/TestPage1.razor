@page "/test-page1"
<div id="thisDivIsNeededForCssIsolationToWork">
     
<Div Name="TestPage1">
        <H1>Test page 1</H1>

    <Div Name="Buttons">
            <Div Name="BasicButtons">
                <PrimaryButton>Primary</PrimaryButton>
                <SecondaryButton>Secondary</SecondaryButton>
                <DestructiveButton>Destructive</DestructiveButton>
            </Div>

            <hr />
            <Div Name="StandardizedButtons">
                <AcceptButton Name="Accept">Accept</AcceptButton>
                <SubmitButton Name="Submit">Submit</SubmitButton>
                <CancelButton Name="Cancel">Cancel</CancelButton>
                <CloseButton Name="CloseForm">X</CloseButton>
                <DeleteButton Name="DeleteStuff">Delete</DeleteButton>
            </Div> 

            <hr />
            <Div Name="DisabledlButtons">
                <Button Specialization="disabled">Disabled</Button>
            </Div> 

            <hr />
            <Div Name="DashedButtons"> 
                <Button Specialization="dash">Dashed</Button>
                <Button Specialization="dash primary">Primary</Button>
                <Button Specialization="dash secondary">Secondary</Button>
                <Button Specialization="dash accent">Accent</Button>
                <Button Specialization="dash info">Info</Button>
                <Button Specialization="dash success">Success</Button>
                <Button Specialization="dash warning">Warning</Button>
                <Button Specialization="dash error">Error</Button> 
            </Div>

            <hr />
            <Div Name="SoftButtons"> 
                <Button Specialization="soft primary">Primary</Button>
                <Button Specialization="soft secondary">Secondary</Button>
                <Button Specialization="soft accent">Accent</Button>
                <Button Specialization="soft info">Info</Button>
                <Button Specialization="soft success">Success</Button>
                <Button Specialization="soft dash warning">Warning</Button>
                <Button Specialization=" btn-soft  btn-dash btn-error">Error</Button>
            </Div>
    </Div>

    <hr />

    <Card Name="Advert">
        <Figure>
            <Img Alt="Shoes" Src="https://img.daisyui.com/images/stock/photo-1606107557195-0e29a4b5b4aa.webp" />
        </Figure>
        <CardBody>
            <CardTitle>Card Title</CardTitle>
            <P>A card component has a figure, a body part, and inside body there are title and actions parts</P>
            <Div class="card-actions justify-end">
                <PrimaryButton Name="BuyButton">Buy Now</PrimaryButton>
            </Div>
        </CardBody>
    </Card>


    <hr />

    <Card> 
        <Header>
            <H2>Meeting Notes</H2>
            <P>Transcript from the meeting with the client.</P>
        </Header>
        <Section Class="text-sm">
            <P>Client requested dashboard redesign with focus on mobile responsiveness.</P>
            <Ol Class="mt-4 flex list-decimal flex-col gap-2 pl-6">
                <Li>New analytics widgets for daily/weekly metrics</Li>
                <Li>Simplified navigation menu</Li>
                <Li>Dark mode support</Li>
                <Li>Timeline: 6 weeks</Li>
                <Li>Follow-up meeting scheduled for next Tuesday</Li>
            </Ol>
        </Section>
        <Footer Class="flex items-center">
            <Div Class="flex -space-x-2 [&_img]:ring-card [&_img]:ring-2 [&_img]:grayscale [&_img]:size-8 [&_img]:shrink-0 [&_img]:object-cover [&_img]:rounded-full">
                <Img Alt="hunvreus" Src="https://github.com/hunvreus.png"/>
                <Img Alt="shadcn" Src="https://github.com/shadcn.png"/>
                <Img Alt="adamwathan" Src="https://github.com/adamwathan.png"/>
            </Div>
        </Footer> 
    </Card>

</Div>


</div>
