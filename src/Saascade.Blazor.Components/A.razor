@inherits BaseComponentWithRequiredChildContent
<CascadingValue Name="Parent" Value="@this" IsFixed="true">
    <a id="@Id" data-name="@Name" data-fullname="@GetFullname()" class="@GetFinalClassNames()" style="@Style" title="@Tooltip" href="@To" target="@Target.Resolve()">@ChildContent</a>
</CascadingValue>
@code
{
    [Parameter, EditorRequired]
    public string To { get; set; }

    [Parameter]
    public HyperlinkTarget Target { get; set; }
}