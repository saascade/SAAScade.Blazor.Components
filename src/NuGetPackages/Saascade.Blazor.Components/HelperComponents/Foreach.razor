@namespace Saascade.Blazor.Components
@typeparam TItem
@foreach (var item in In)
{
	@if (ShowItemsWhen)
	{
		@ChildContent(item)
	}
}
@code
{
	[Parameter, EditorRequired] public required RenderFragment<TItem> ChildContent { get; set; }
	[Parameter, EditorRequired] public required IEnumerable<TItem> In { get; set; } = [];
	[Parameter] public bool ShowItemsWhen { get; set; } = true;
}